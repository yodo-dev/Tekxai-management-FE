{
  "name": "tekxai-agent",
  "version": "1.0.0",
  "description": "TekXAI Desktop Agent — time tracking & screenshot monitoring",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.tekxai.agent",
    "productName": "TekXAI Agent",
    "icon": "assets/icon.png",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "TekXAI-Agent-Setup.exe"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "TekXAI-Agent.dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "TekXAI-Agent.AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0",
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
